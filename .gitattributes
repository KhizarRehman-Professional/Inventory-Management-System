# Force C++ as the primary language - hide everything else
*.cpp linguist-detectable=true
*.h linguist-detectable=true
*.hpp linguist-detectable=true

# Hide data/config files from language stats
*.txt linguist-vendored=true
*.md linguist-documentation=true

# If you have any web files in the repo, hide them
*.html linguist-vendored=true
*.css linguist-vendored=true
*.js linguist-vendored=true
